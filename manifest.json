{
  "manifest_version": 3,
  "name": "GPTSkin",
  "version": "1.0",
  "description": "Customize ChatGPT themes and wallpapers",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://chatgpt.com/*"],
  "icons": {
  "16": "icons/GPTSkin-logo-16.png",
  "48": "icons/GPTSkin-logo-48.png",
  "128": "icons/GPTSkin-logo-128.png"
},
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
  "default_icon": {
    "16": "icons/GPTSkin-logo-16.png",
    "48": "icons/GPTSkin-logo-48.png"
  }
  }
}